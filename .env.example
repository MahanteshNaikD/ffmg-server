PORT=8080
NODE_ENV=development

# Server A URL reachable from Server B
SERVER_A_INTERNAL_URL=http://localhost:3000
SERVER_A_API_PREFIX=/api/v1

# Heartbeat cadence in milliseconds
HEARTBEAT_INTERVAL_MS=2000

# RTMP ingest source base URL (nginx-rtmp/live)
RTMP_INPUT_BASE=rtmp://localhost/live

# Directory where HLS outputs are written and served from /hls
HLS_ROOT=./hls-output

# No spaces around =. Requires GOOGLE_APPLICATION_CREDENTIALS or GCP metadata credentials.
GCS_BUCKET=video_stream_dev_us_region
GCS_HLS_PREFIX=live_stream
